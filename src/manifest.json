{
  "manifest_version": 3,
  "name": "jxmis-extension",
  "version": "1.0.0",
  "description": "Chrome extension for JXMIS daily approval and batch work automation.",
  "action": {},
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jxmis.cyberwing.cn/jxpmo/*"
      ],
      "js": [
        "background.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://jxmis.cyberwing.cn/jxpmo/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "host_permissions": [
    "https://jxmis.cyberwing.cn/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-daily-approval.js",
        "page-batch-work.js",
        "page-weekly-approval.js",
        "page-business-analytics.js",
        "business-analytics.css"
      ],
      "matches": [
        "https://jxmis.cyberwing.cn/*"
      ]
    }
  ]
}
