{
  "manifest_version": 3,
  "name": "jxmis-extension",
  "version": "1.0.0",
  "description": "Chrome extension for JXMIS daily approval and batch work automation.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jxmis.cyberwing.cn/jxpmo/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://jxmis.cyberwing.cn/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "project-manager-override.js",
        "jxmis-transport.js",
        "page-daily-approval.js",
        "wbs-plan.js",
        "daily-actual.js",
        "current-week-execution-plan.js",
        "weekly-summary.js",
        "weekly-detail.js",
        "weekly-context.js",
        "page-batch-work.js",
        "page-weekly-approval.js"
      ],
      "matches": [
        "https://jxmis.cyberwing.cn/*"
      ]
    }
  ]
}
